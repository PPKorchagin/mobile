{
    "table": "fct_geo_intervals",
    "description": "Интервалы пребывания абонента, агрегированные из stg_geo_all по методике AGG_GEO_INTERVALS",
    "fields": [
        { "name": "msisdn", "type": "long", "comment": "MSISDN абонента" },
        { "name": "imsi", "type": "long", "comment": "IMSI абонента" },
        { "name": "imei", "type": "long", "comment": "IMEI абонента (с дозаполнением из fct_msisdn_imei)" },
        { "name": "start_time_utc", "type": "timestamp", "comment": "Начало интервала в UTC" },
        { "name": "end_time_utc", "type": "timestamp", "comment": "Конец интервала в UTC" },
        { "name": "cgi_list", "type": "list<string>", "comment": "Уникальные CGI в интервале (отсортированные)" },
        { "name": "sub_lat", "type": "double", "comment": "Оценочная широта абонента" },
        { "name": "sub_lon", "type": "double", "comment": "Оценочная долгота абонента" },
        { "name": "bs_type", "type": "string", "comment": "Тип БС интервала (m/f/i/x/o)" },
        { "name": "timezone", "type": "int", "comment": "Смещение от UTC в часах" },
        { "name": "oktmo_code_1", "type": "string", "comment": "Доминирующий ОКТМО уровня 1" },
        { "name": "oktmo_code_2", "type": "string", "comment": "Доминирующий ОКТМО уровня 2" },
        { "name": "time_key", "type": "date", "comment": "Календарный день среза (UTC)" }
    ]
}
