{
    "table": "fct_bs",
    "description": "Справочник базовых станций: снимок src_bs, активных на отчётную дату, без SCD-истории в parquet",
    "fields": [
        { "name": "mcc", "type": "smallint", "comment": "Mobile country code" },
        { "name": "mnc", "type": "smallint", "comment": "Mobile network code" },
        { "name": "lac", "type": "int", "comment": "Location area code" },
        { "name": "cell_id", "type": "long", "comment": "Cell ID базовой станции" },
        { "name": "telecomstandard", "type": "string", "comment": "Стандарт связи 2G/3G/4G" },
        { "name": "frequency", "type": "int", "comment": "Рабочая частота, МГц" },
        { "name": "lon", "type": "float", "comment": "Расчётная долгота БС" },
        { "name": "lat", "type": "float", "comment": "Расчётная широта БС" },
        { "name": "lon_original", "type": "float", "comment": "Исходная долгота БС" },
        { "name": "lat_original", "type": "float", "comment": "Исходная широта БС" },
        { "name": "bs_type", "type": "string", "comment": "Тип БС: m/f/i/x/o" },
        { "name": "sector_angle", "type": "float", "comment": "Угол сектора, градусы" },
        { "name": "sector_azimuth", "type": "float", "comment": "Азимут сектора, градусы" },
        { "name": "sector_radius", "type": "float", "comment": "Радиус покрытия, км" },
        { "name": "position_code", "type": "string", "comment": "Код позиции БС (avtocod)" },
        { "name": "h3", "type": "string", "comment": "H3 индекс (resolution 15)" },
        { "name": "timezone", "type": "smallint", "comment": "UTC offset в часах по координатам" },
        { "name": "mapinfo_wkt", "type": "string", "comment": "MAPINFO: мозаика Вороного по telecomstandard+frequency" },
        { "name": "mapinfo_wkt_area", "type": "float", "comment": "Площадь mapinfo_wkt, км²" },
        { "name": "mapinfo_wkt_centroid_lon", "type": "float", "comment": "Долгота центроида mapinfo_wkt" },
        { "name": "mapinfo_wkt_centroid_lat", "type": "float", "comment": "Широта центроида mapinfo_wkt" },
        { "name": "sector_wkt", "type": "string", "comment": "Секторное покрытие (WKT)" },
        { "name": "sector_wkt_area", "type": "float", "comment": "Площадь sector_wkt, км²" },
        { "name": "sector_wkt_centroid_lon", "type": "float", "comment": "Долгота центроида sector_wkt" },
        { "name": "sector_wkt_centroid_lat", "type": "float", "comment": "Широта центроида sector_wkt" },
        { "name": "oktmo_code_1", "type": "string", "comment": "ОКТМО уровень 1" },
        { "name": "oktmo_code_2", "type": "string", "comment": "ОКТМО уровень 2" },
        { "name": "date_on", "type": "timestamp", "comment": "Начало интервала витрины (= report_date)" },
        { "name": "date_off", "type": "timestamp", "comment": "Открытый конец (2262-04-11)" }
    ]
}
