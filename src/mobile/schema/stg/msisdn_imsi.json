{
    "table": "stg_msisdn_imsi",
    "description": "Месячные интервалы MSISDN–IMSI + operator_id (файл YYYY-MM-01), ежедневный инкремент из stg_geo_all (наблюдения)",
    "fields": [
        {
            "name": "msisdn",
            "type": "string",
            "comment": "MSISDN, E.164 (RU и иностранные номера)"
        },
        {
            "name": "imsi",
            "type": "string",
            "comment": "IMSI, 14–15 цифр (MCC+MNC+MSIN)"
        },
        {
            "name": "operator_id",
            "type": "long",
            "comment": "MNC (цифры 4–5) при MCC 250; для иностранных IMSI — null"
        },
        {
            "name": "valid_from",
            "type": "timestamp",
            "comment": "Начало интервала наблюдения"
        },
        {
            "name": "valid_to",
            "type": "timestamp",
            "comment": "Конец интервала наблюдения"
        }
    ]
}
