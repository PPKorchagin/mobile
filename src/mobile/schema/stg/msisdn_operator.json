{
  "table": "stg_msisdn_operator",
  "description": "Интервалы наблюдения MSISDN + operator_id (+ imsi) из src_person за месяц (MNP)",
  "fields": [
    { "name": "msisdn", "type": "string", "comment": "Нормализованный MSISDN" },
    { "name": "operator_id", "type": "long", "comment": "operator_Id из src_person" },
    { "name": "imsi", "type": "string", "comment": "IMSI на интервале (может быть null)" },
    { "name": "valid_from", "type": "timestamp", "comment": "Начало интервала" },
    { "name": "valid_to", "type": "timestamp", "comment": "Конец интервала" }
  ]
}
