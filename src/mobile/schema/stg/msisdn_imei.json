{
    "table": "stg_msisdn_imei",
    "description": "Интервалы актуальности связки MSISDN–IMEI по наблюдениям event_dds за отчётный день",
    "fields": [
        {
            "name": "msisdn",
            "type": "string",
            "comment": "MSISDN, E.164 (RU и иностранные номера)"
        },
        {
            "name": "imei",
            "type": "string",
            "comment": "IMEI, 14–16 цифр"
        },
        {
            "name": "valid_from",
            "type": "timestamp",
            "comment": "Первое событие интервала (локальное время event_timestamp)"
        },
        {
            "name": "valid_to",
            "type": "timestamp",
            "comment": "Последнее событие интервала (локальное время)"
        }
    ]
}
